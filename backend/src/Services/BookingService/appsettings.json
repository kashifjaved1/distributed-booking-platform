{
  "ConnectionStrings": {
    "BookingDB": "Host=localhost;Port=5432;Database=BookingDB;Username=postgres;Password=postgres;Include Error Detail=true",
    "RabbitMQ": "amqp://guest:guest@localhost:5672"
  },
  "RabbitMQ": {
    "booking": {
      "Host": "localhost",
      "Port": 5672,
      "UserName": "guest",
      "Password": "guest",
      "VirtualHost": "/",
      "PrefetchCount": 10,
      "MaxRetryAttempts": 5,
      "RetryDelayMs": 1000
    }
  },
  "Outbox": {
    "PollingIntervalMs": 1000,
    "BatchSize": 50,
    "MaxRetryCount": 5
  },
  "OpenTelemetry": {
    "OtlpExporter": {
      "Endpoint": "http://localhost:4317"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "BookingService": "Debug"
    }
  },
  "AllowedHosts": "*"
}
