{
  "ConnectionStrings": {
    "NotificationDB": "Host=localhost;Port=5432;Database=NotificationDB;Username=postgres;Password=postgres",
    "RabbitMQ": "amqp://guest:guest@localhost:5672"
  },
  "RabbitMQ": {
    "notification": {
      "Host": "localhost",
      "Port": 5672,
      "UserName": "guest",
      "Password": "guest",
      "PrefetchCount": 10,
      "MaxRetryAttempts": 5
    }
  },
  "Outbox": {
    "PollingIntervalMs": 1000,
    "BatchSize": 50,
    "MaxRetryCount": 5
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "NotificationService": "Debug"
    }
  }
}
